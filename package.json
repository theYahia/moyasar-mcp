{
  "name": "@theyahia/moyasar-mcp",
  "version": "1.0.0",
  "description": "MCP server for Moyasar payment gateway (Saudi Arabia)",
  "type": "module",
  "main": "dist/index.js",
  "bin": { "moyasar-mcp": "dist/index.js" },
  "files": ["dist"],
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "publishConfig": { "access": "public" },
  "mcpName": "io.github.theYahia/moyasar-mcp",
  "keywords": ["mcp", "mcp-server", "model-context-protocol", "claude", "ai", "moyasar", "saudi-api", "payments", "typescript"],
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/theYahia/moyasar-mcp.git" },
  "homepage": "https://github.com/theYahia/moyasar-mcp#readme",
  "author": "theYahia (https://github.com/theYahia)"
